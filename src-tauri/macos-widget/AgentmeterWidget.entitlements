<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Sandbox-only for the free-team MVP. No App Group (free Apple teams
       auto-prefix App Group ids with the team id, breaking the Rust writer's
       fixed-id path). App Group entitlements move to Phase 4 (paid Developer
       ID) where the team prefix is known and registered upstream. -->
  <key>com.apple.security.app-sandbox</key>
  <true/>
</dict>
</plist>
